{
  "name": "time-deposit-kata",
  "version": "1.0.0",
  "description": "Time Deposit Repository",
  "author": "Mauricio Collis",
  "license": "MIT",
  "scripts": {
    "build": "tsc --outDir dist --declaration false --inlineSourceMap false --inlineSources false",
    "watch": "tsc -w",
    "test": "jest",
    "test:domain": "jest --testPathPattern=src/tests/*",
    "dev:local": "npx ts-node src/adapters/driving/server.ts",
    "docker:build": "docker build -t time-deposit-api .",
    "docker:run": "docker run --read-only --cap-drop ALL --security-opt no-new-privileges --pids-limit 100 --memory=512m --cpus=1 -p 3000:3000 time-deposit-api"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2",
    "express": "^4.21.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.170.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0",
    "@types/jest": "^29.5.14",
    "jest-util": "^30.3.0"
  }
}
